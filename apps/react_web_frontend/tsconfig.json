{
  "extends": "@shared/config/tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@shared/ui": ["../../packages/ui/src"],
      "@shared/ui/*": ["../../packages/ui/src/*"],
      "@shared/auth": ["../../packages/auth/src"],
      "@shared/auth/*": ["../../packages/auth/src/*"],
      "@shared/api": ["../../packages/api/src"],
      "@shared/api/*": ["../../packages/api/src/*"],
      "@shared/utils": ["../../packages/utils/src"],
      "@shared/utils/*": ["../../packages/utils/src/*"],
      "@web/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
