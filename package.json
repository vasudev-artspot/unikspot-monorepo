{
  "name": "unikspot-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "tsc": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "spell:check": "cspell \"**/*.{ts,tsx,md,yml}\" --no-progress",
    "ci": "pnpm lint && pnpm tsc && pnpm format:check && pnpm knip && pnpm spell:check && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "cspell": "^10.0.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globals": "^16.0.0",
    "knip": "^6.16.1",
    "prettier": "3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  }
}
